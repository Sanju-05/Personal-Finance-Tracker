@{
    ViewData["Title"] = "Dashboard";
}

<!-- Dashboard Menu -->
<div class="container d-flex flex-column justify-content-center min-vh-100" style="transform: translateY(-20%);">
    <div class="text-center mb-5 center-flex">
        <h2 class="mb-4">Dashboard</h2>
        <div class="d-grid gap-3">
            <a class="btn btn-primary btn-lg w-100" asp-controller="transaction" asp-action="Index">Transaction List</a>
            <a class="btn btn-success btn-lg w-100" asp-controller="transaction" asp-action="Create">Add Transaction</a>
            <a class="btn btn-info btn-lg w-100" asp-controller="transaction" asp-action="TransactionReport">Show Transaction</a>
        </div>
    </div>
</div>

<!-- Optional Custom Styles -->
<style>
    .d-grid {
        display: grid;
        grid-template-columns: 1fr;
        row-gap: 20px;
        width: 300px;
    }
</style>
